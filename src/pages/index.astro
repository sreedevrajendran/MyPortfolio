---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Hero from '../components/Hero';
import About from '../components/About';
import Skills from '../components/Skills';
import ProjectsPreview from '../components/ProjectsPreview';
import BlogPreview from '../components/BlogPreview';
import Contact from '../components/Contact';
import Footer from '../components/Footer';
---

<Layout
  title="Sreedev Rajendran | Developer | Visual Creator | Founder of topviewframes"
  description="Portfolio of Sreedev Rajendran — B.Tech CS & AI student, full-stack developer, and founder of @topviewframes. Building AI-native apps with Next.js, Python, React Native, and Google Gemini."
  url="https://sreedevrajendran.in/"
>
  <main class="flex flex-col w-full">
    <Navbar client:load />
    <div class="max-w-6xl mx-auto px-4 md:px-8 w-full flex flex-col space-y-28 pb-16 pt-24">
      <Hero client:load />
      <About client:visible />
      <Skills client:visible />
      <ProjectsPreview client:visible />
      <BlogPreview client:visible />
      <Contact client:visible />
      <Footer />
    </div>
  </main>
</Layout>
